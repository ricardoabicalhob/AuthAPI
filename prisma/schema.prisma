generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String    @id @default(uuid())
  email                  String    @unique
  password               String
  passwordResetToken     String?
  passwordResetExpiresAt DateTime?
  passwordChangeAt       DateTime?
  deletedAt              DateTime?
}
